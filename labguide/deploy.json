{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "CloudLabs Environment - EC2 (Password Login) + S3 Bucket",

  "Parameters": {
    "CloudLabsDeploymentID": {
      "Type": "String"
    },
    "AdminUsername": {
      "Type": "String",
      "Default": "labuser"
    },
    "AdminPassword": {
      "Type": "String",
      "NoEcho": true
    },
    "CheckAcknowledgement": {
      "Type": "String",
      "Default": "TRUE",
      "AllowedValues": ["TRUE", "FALSE"]
    }
  },

  "Resources": {

    "VPC": {
      "Type": "AWS::EC2::VPC",
      "Properties": {
        "CidrBlock": "10.0.0.0/16",
        "EnableDnsSupport": true,
        "EnableDnsHostnames": true,
        "Tags": [{
          "Key": "Name",
          "Value": { "Fn::Sub": "vpc-${CloudLabsDeploymentID}" }
        }]
      }
    },

    "Subnet": {
      "Type": "AWS::EC2::Subnet",
      "Properties": {
        "VpcId": { "Ref": "VPC" },
        "CidrBlock": "10.0.1.0/24",
        "MapPublicIpOnLaunch": true,
        "AvailabilityZone": { "Fn::Sub": "${AWS::Region}a" },
        "Tags": [{
          "Key": "Name",
          "Value": { "Fn::Sub": "subnet-${CloudLabsDeploymentID}" }
        }]
      }
    },

    "InternetGateway": {
      "Type": "AWS::EC2::InternetGateway",
      "Properties": {
        "Tags": [{
          "Key": "Name",
          "Value": { "Fn::Sub": "igw-${CloudLabsDeploymentID}" }
        }]
      }
    },

    "AttachGateway": {
      "Type": "AWS::EC2::VPCGatewayAttachment",
      "Properties": {
        "VpcId": { "Ref": "VPC" },
        "InternetGatewayId": { "Ref": "InternetGateway" }
      }
    },

    "RouteTable": {
      "Type": "AWS::EC2::RouteTable",
      "Properties": {
        "VpcId": { "Ref": "VPC" },
        "Tags": [{
          "Key": "Name",
          "Value": { "Fn::Sub": "rtb-${CloudLabsDeploymentID}" }
        }]
      }
    },

    "Route": {
      "Type": "AWS::EC2::Route",
      "DependsOn": "AttachGateway",
      "Properties": {
        "RouteTableId": { "Ref": "RouteTable" },
        "DestinationCidrBlock": "0.0.0.0/0",
        "GatewayId": { "Ref": "InternetGateway" }
      }
    },

    "SubnetAssociation": {
      "Type": "AWS::EC2::SubnetRouteTableAssociation",
      "Properties": {
        "SubnetId": { "Ref": "Subnet" },
        "RouteTableId": { "Ref": "RouteTable" }
      }
    },

    "SecurityGroup": {
      "Type": "AWS::EC2::SecurityGroup",
      "Properties": {
        "VpcId": { "Ref": "VPC" },
        "GroupDescription": "Allow SSH Password Login",
        "SecurityGroupIngress": [{
          "IpProtocol": "tcp",
          "FromPort": 22,
          "ToPort": 22,
          "CidrIp": "0.0.0.0/0"
        }],
        "Tags": [{
          "Key": "Name",
          "Value": { "Fn::Sub": "sg-${CloudLabsDeploymentID}" }
        }]
      }
    },

    "EC2Instance": {
      "Type": "AWS::EC2::Instance",
      "Properties": {
        "InstanceType": "t3.micro",
        "ImageId": {
          "Fn::Sub": "{{resolve:ssm:/aws/service/ami-amazon-linux-latest/al2023-ami-kernel-default-x86_64}}"
        },
        "SubnetId": { "Ref": "Subnet" },
        "SecurityGroupIds": [{ "Ref": "SecurityGroup" }],
        "Tags": [{
          "Key": "Name",
          "Value": { "Fn::Sub": "lab-vm-${CloudLabsDeploymentID}" }
        }]
      }
    },

    "LabS3Bucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": {
          "Fn::Sub": "lab-bucket-${CloudLabsDeploymentID}"
        },
        "Tags": [{
          "Key": "Name",
          "Value": { "Fn::Sub": "lab-bucket-${CloudLabsDeploymentID}" }
        }]
      }
    },

    "TaskExecutionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [{
            "Effect": "Allow",
            "Principal": {
              "Service": ["ecs-tasks.amazonaws.com"]
            },
            "Action": ["sts:AssumeRole"]
          }]
        },
        "Path": "/",
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        ],
        "Tags": [{
          "Key": "Name",
          "Value": {
            "Fn::Sub": "TaskExecutionRole-${CloudLabsDeploymentID}"
          }
        }]
      }
    }

  },

  "Outputs": {
    "CloudLabsDeploymentID": {
      "Value": { "Ref": "CloudLabsDeploymentID" }
    },
    "AWSAccountID": {
      "Value": { "Ref": "AWS::AccountId" }
    },
    "Region": {
      "Value": { "Ref": "AWS::Region" }
    },
    "VpcId": {
      "Value": { "Ref": "VPC" }
    },
    "SubnetId": {
      "Value": { "Ref": "Subnet" }
    },
    "SecurityGroupId": {
      "Value": { "Ref": "SecurityGroup" }
    },
    "InstanceId": {
      "Value": { "Ref": "EC2Instance" }
    },
    "VMName": {
      "Value": "lab-vm"
    },
    "EC2PublicIP": {
      "Value": { "Fn::GetAtt": ["EC2Instance", "PublicIp"] }
    },
    "EC2PrivateIP": {
      "Value": { "Fn::GetAtt": ["EC2Instance", "PrivateIp"] }
    },
    "EC2PublicDNS": {
      "Value": { "Fn::GetAtt": ["EC2Instance", "PublicDnsName"] }
    },
    "EC2PrivateDNS": {
      "Value": { "Fn::GetAtt": ["EC2Instance", "PrivateDnsName"] }
    },
    "S3BucketName": {
      "Value": { "Ref": "LabS3Bucket" }
    },
    "Username": {
      "Value": { "Ref": "AdminUsername" }
    },
    "Password": {
      "Value": { "Ref": "AdminPassword" }
    },
    "TaskExecutionRole": {
      "Value": {
        "Fn::GetAtt": ["TaskExecutionRole", "Arn"]
      }
    }
  }
}
